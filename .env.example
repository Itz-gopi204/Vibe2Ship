# Google AI Studio Gemini API Key Configuration
# Copy this file to ".env" at the project root and fill in the values below.
# The backend uses SUPABASE_DB_URL / DATABASE_URL to determine whether to connect to Postgres.
# If no DB URL is provided, the app will automatically fall back to local SQLite with civic_hero.db.

# Primary Gemini API key used by the backend service.
VITE_GEMINI_API_KEY=

# Alternate Gemini key alias accepted by backend code.
GEMINI_API_KEY=

# Preferred database URL for PostgreSQL / Supabase.
# Example: postgresql://postgres:password@db.example.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Optional fallback database URL alias.
DATABASE_URL=

# Optional local simulation mode flag (not required for core backend operation).
VITE_SIMULATION_MODE=false
