# Google AI Studio Gemini API Key Configuration
# Copy this file to ".env" at the project root and fill in the values below.
# The backend uses MONGODB_URI and MONGODB_DB_NAME to connect to MongoDB.
# If no MongoDB URI is provided, the app will automatically fall back to local SQLite with civic_hero.db.

# Primary Gemini API key used by the backend service.
VITE_GEMINI_API_KEY=

# Alternate Gemini key alias accepted by backend code.
GEMINI_API_KEY=

# MongoDB connection URI.
# Example: mongodb+srv://user:password@cluster0.mongodb.net/vibe2ship?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=vibe2ship

# Optional local simulation mode flag (not required for core backend operation).
VITE_SIMULATION_MODE=false

# Primary frontend API backend URL for production deployment (e.g. Vercel).
# Example: https://vibe2ship.onrender.com
VITE_API_BASE_URL=
